{
  "name": "mulby-cli",
  "version": "1.1.10",
  "description": "Mulby 插件开发 CLI 工具",
  "main": "dist/index.js",
  "files": [
    "dist",
    "assets"
  ],
  "bin": {
    "mulby": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && node scripts/copy-ai-assets.mjs",
    "check:template-api-sync": "node scripts/check-template-api-sync.mjs",
    "dev": "tsc -w",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm run check:template-api-sync && npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@vercel/nft": "^1.3.2",
    "archiver": "^7.0.0",
    "chalk": "^4.1.2",
    "chokidar": "^3.6.0",
    "commander": "^12.0.0",
    "esbuild": "^0.20.0",
    "fs-extra": "^11.2.0",
    "ink": "^3.2.0",
    "ink-select-input": "^4.2.2",
    "ink-text-input": "^4.0.3",
    "inquirer": "^13.2.0",
    "js-tiktoken": "^1.0.21",
    "openai": "^6.16.0",
    "react": "^17.0.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.0",
    "@types/fs-extra": "^11.0.0",
    "@types/ink-text-input": "^2.0.5",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^20.0.0",
    "@types/react": "^17.0.2",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.0.0"
  }
}